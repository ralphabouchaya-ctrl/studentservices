@page
@model MyRazorApp.Pages.Students.EditStudentModel

@{
    ViewData["Title"] = "Edit Student";
    Layout = "";
}

<div class="container">
    <h2>Edit Student</h2>

    <form method="post">

        <input type="hidden" asp-for="Student.Id" />

        <div>
            <label for="FirstName">First Name:</label>
            <input type="text"
                   id="FirstName"
                   name="Student.FirstName"
                   value="@Model.Student.FirstName"
                   required />
        </div>

        <div>
            <label for="LastName">Last Name:</label>
            <input type="text"
                   id="LastName"
                   name="Student.LastName"
                   value="@Model.Student.LastName"
                   required />
        </div>

        <div>
            <label for="Email">Email:</label>
            <input type="email"
                   id="Email"
                   name="Student.Email"
                   value="@Model.Student.Email"
                   required />
        </div>

        <div>
            <label for="Address">Address:</label>
            <textarea id="Address"
                      name="Student.Address"
                      required>@Model.Student.Address</textarea>
        </div>

        <div>
            <label for="Gender">Gender:</label>
            <select id="Gender"
                    name="Student.Gender"
                    required>

                <option value="Male"
                    selected="@(Model.Student.Gender == "Male")">
                    Male
                </option>

                <option value="Female"
                    selected="@(Model.Student.Gender == "Female")">
                    Female
                </option>

                <option value="Other"
                    selected="@(Model.Student.Gender == "Other")">
                    Other
                </option>

            </select>
        </div>

        <div>
            <input type="submit" value="Update Student" />
        </div>
    </form>
</div>

<style>
    body {
        font-family: Arial, sans-serif;
        background-color: #f4f6f9;
    }

    .container {
        width: 400px;
        margin: 50px auto;
        background: white;
        padding: 25px;
        border-radius: 10px;
        box-shadow: 0px 0px 10px rgba(0,0,0,0.1);
    }

    h2 {
        text-align: center;
        margin-bottom: 20px;
        color: #333;
    }

    form div {
        margin-bottom: 15px;
    }

    label {
        display: block;
        margin-bottom: 5px;
        font-weight: bold;
    }

    input,
    textarea,
    select {
        width: 100%;
        padding: 10px;
        border: 1px solid #ccc;
        border-radius: 5px;
        font-size: 14px;
    }

    textarea {
        resize: vertical;
        height: 80px;
    }

    input[type="submit"] {
        background-color: #007bff;
        color: white;
        border: none;
        cursor: pointer;
        font-size: 16px;
        transition: 0.3s;
    }

    input[type="submit"]:hover {
        background-color: #0056b3;
    }
</style>